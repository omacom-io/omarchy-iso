#!/bin/bash

set -e

NO_CACHE=""
LOCAL_OMARCHY_PATH=""
LOCAL_PKGS_PATH=""
while [[ $# -gt 0 ]]; do
  case $1 in
  --no-cache)
    NO_CACHE=1
    shift
    ;;
  --no-boot-offer)
    NO_BOOT_OFFER=1
    shift
    ;;
  --debug)
    OMARCHY_INSTALL_DEBUG=1
    shift
    ;;
  --local-source)
    LOCAL_OMARCHY_PATH="${2:-}"
    LOCAL_PKGS_PATH="${3:-}"
    if [[ -z $LOCAL_OMARCHY_PATH || -z $LOCAL_PKGS_PATH ]]; then
      echo "Error: --local-source requires two args: <omarchy-checkout> <pkgs-checkout>" >&2
      exit 1
    fi
    OMARCHY_MIRROR=edge
    OMARCHY_ISO_REF=local
    shift 3
    ;;
  --dev)
    OMARCHY_ISO_REF=dev
    OMARCHY_MIRROR=edge
    shift
    ;;
  --rc)
    OMARCHY_ISO_REF=rc
    OMARCHY_MIRROR=rc
    shift
    ;;
  *)
    echo "Unknown option: $1"
    echo "Usage: $0 [--no-cache] [--no-boot-offer] [--debug] [--dev|--rc] [--local-source <omarchy-checkout> <pkgs-checkout>]"
    exit 1
    ;;
  esac
done

if [[ -n $LOCAL_OMARCHY_PATH ]]; then
  [[ -d $LOCAL_OMARCHY_PATH ]] || { echo "Error: Omarchy checkout not found at $LOCAL_OMARCHY_PATH" >&2; exit 1; }
  [[ -d $LOCAL_PKGS_PATH ]]    || { echo "Error: pkgs checkout not found at $LOCAL_PKGS_PATH" >&2; exit 1; }
  LOCAL_OMARCHY_PATH=$(realpath "$LOCAL_OMARCHY_PATH")
  LOCAL_PKGS_PATH=$(realpath "$LOCAL_PKGS_PATH")
fi

lint_file_permissions() {
  local profiledef="configs/profiledef.sh"
  local -A declared=()
  local missing=()

  while IFS= read -r path; do
    [[ -n $path ]] && declared["$path"]=1
  done < <(grep -oP '^\s*\["\K[^"]+(?="\])' "$profiledef" || true)

  while IFS= read -r f; do
    [[ -f $f ]] || continue

    local rel="${f#configs/airootfs}"
    local mode
    mode=$(git ls-files --stage -- "$f" | awk '{print $1}')

    if [[ $mode != 100755 && $(head -c 2 "$f") != "#!" ]]; then
      continue
    fi

    if [[ -z ${declared[$rel]+x} ]]; then
      missing+=("$rel")
    fi
  done < <(find configs/airootfs/usr/local/bin configs/airootfs/root -type f 2>/dev/null)

  if (( ${#missing[@]} > 0 )); then
    echo "ERROR: the following executable files are missing from $profiledef file_permissions:" >&2
    printf '  %s\n' "${missing[@]}" >&2
    echo "Add entries like [\"<path>\"]=\"0:0:755\" to profiledef.sh and retry." >&2
    exit 1
  fi
}

lint_file_permissions

sudo rm -rf /var/cache/pacman/pkg/*
git submodule update --init --recursive --jobs=8

BUILD_SCRIPT="builder/build-iso.sh"
BUILD_ROOT=$(realpath "${BASH_SOURCE[0]%/*}/..")
BUILD_RELEASE_PATH="$BUILD_ROOT/release"
mkdir -p "$BUILD_RELEASE_PATH"

OMARCHY_ISO_REF="${OMARCHY_ISO_REF:-stable}"
OMARCHY_MIRROR="${OMARCHY_MIRROR:-stable}"

DOCKER_ARGS=(
  --rm
  --privileged
  -e "OMARCHY_ISO_REF=$OMARCHY_ISO_REF"
  -e "OMARCHY_MIRROR=$OMARCHY_MIRROR"
  -e "OMARCHY_INSTALL_DEBUG=${OMARCHY_INSTALL_DEBUG:-}"
  -e "HOST_UID=$(id -u)"
  -e "HOST_GID=$(id -g)"
  -v "$BUILD_RELEASE_PATH/:/out/"
  -v "$BUILD_ROOT/$BUILD_SCRIPT:/$BUILD_SCRIPT:ro"
  -v "$BUILD_ROOT/archiso:/archiso:ro"
  -v "$BUILD_ROOT/builder:/builder:ro"
  -v "$BUILD_ROOT/configs:/configs:ro"
)

if [[ -n $LOCAL_OMARCHY_PATH ]]; then
  DOCKER_ARGS+=(
    -v "$LOCAL_OMARCHY_PATH:/omarchy-source:ro"
    -v "$LOCAL_PKGS_PATH:/omarchy-pkgs:ro"
  )
fi

if [[ -d /var/cache/pacman/pkg ]]; then
  DOCKER_ARGS+=(-v "/var/cache/pacman/pkg:/var/cache/pacman/pkg")
fi

if [[ -z $NO_CACHE ]]; then
  OFFLINE_REPO_BUILD_CACHE_DIR="$HOME/.cache/omarchy/iso_${OMARCHY_MIRROR}/airootfs/var/cache/omarchy"
  mkdir -p "$OFFLINE_REPO_BUILD_CACHE_DIR"
  DOCKER_ARGS+=(-v "$OFFLINE_REPO_BUILD_CACHE_DIR:/var/cache/airootfs/var/cache/omarchy")
fi

docker run "${DOCKER_ARGS[@]}" archlinux/archlinux:latest /$BUILD_SCRIPT

latest_iso=$(\ls -t "$BUILD_RELEASE_PATH"/*.iso | head -n1)
iso_ref="${latest_iso%.*}-$OMARCHY_ISO_REF.iso"
mv -f "$latest_iso" "$iso_ref"

if [[ -z "${NO_BOOT_OFFER:-}" ]]; then
  echo
  gum confirm "Boot $iso_ref?" && omarchy-iso-boot "$iso_ref"
fi
