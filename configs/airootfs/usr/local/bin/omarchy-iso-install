#!/bin/bash
#
# Live-ISO entry point for the Omarchy install orchestrator. Invoked from
# /root/.automated_script.sh after the configurator wizard has produced
# user_configuration.json / user_credentials.json / user_full_name.txt /
# user_email_address.txt / user_encrypt_installation.txt.
#
# Just sets cwd so 'python -m orchestrator.main' can find the package,
# then hands off all args.

set -eEo pipefail

cd /usr/share/omarchy-iso
exec python -m orchestrator.main "$@"
