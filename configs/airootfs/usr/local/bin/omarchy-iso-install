#!/bin/bash
#
# Live-ISO entry point for the Omarchy install orchestrator. Invoked from
# /root/.automated_script.sh after the configurator wizard has produced its
# user_*.json / user_*.txt files. The outer shim owns install logging.

set -eEo pipefail

# Patch archinstall BEFORE Python loads it. orchestrator/main.py top-level
# imports archinstall_adapter, which top-level imports archinstall.*; patching
# inside a phase would be too late (bytecode already loaded).
omarchy-iso-patch-archinstall

cd /usr/share/omarchy-iso
exec python -m orchestrator.main "$@"
