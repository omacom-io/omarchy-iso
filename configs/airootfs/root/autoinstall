# Generate user_credentials.json
generate_user_credentials() {
  local username="$1"
  local password_hash="$2"

  log "Generating user_credentials.json..."

  cat > user_credentials.json << EOF
{
  "!users": [
    {
      "!password": "$password_hash",
      "sudo": true,
      "username": "$username"
    }
  ]
}
EOF

  log "Created user_credentials.json"
}

# Generate placeholder files that the installer expects
generate_placeholder_files() {
  local username="$1"

  # These files are read by chroot_bash in .automated_script.sh
  echo "$username" > user_full_name.txt
  echo "${username}@localhost" > user_email_address.txt

  log "Created placeholder files"
}

# Setup SSH authorized keys for the installed system
setup_ssh_keys() {
  local username="$1"
  local ssh_keys_json="$2"

  if [[ "$ssh_keys_json" == "[]" ]]; then
    log "No SSH keys to configure"
    return
  fi

  log "SSH keys will be configured after archinstall completes"

  # Save keys to a temp file that post-install can use
  echo "$ssh_keys_json" > /tmp/autoinstall_ssh_keys.json
}

# Post-install hook to set up SSH keys (called from .automated_script.sh context)
setup_ssh_keys_post_install() {
  if [[ ! -f /tmp/autoinstall_ssh_keys.json ]]; then
    return
  fi

  local username
  username=$(jq -r '.users[0].username' user_credentials.json)
  local ssh_dir="/mnt/home/$username/.ssh"

  mkdir -p "$ssh_dir"
  chmod 700 "$ssh_dir"

  jq -r '.[]' /tmp/autoinstall_ssh_keys.json > "$ssh_dir/authorized_keys"
  chmod 600 "$ssh_dir/authorized_keys"
  chown -R 1000:1000 "$ssh_dir"

  # Enable sshd
  arch-chroot /mnt systemctl enable sshd

  log "SSH keys configured and sshd enabled"
}

main() {
  log "Starting unattended installation..."

  # Mount cloud-init drive
  mount_cidata

  # Read configuration
  local username hostname timezone keyboard password disk ssh_keys
  username=$(get_yaml_value "username" "")
  password=$(get_yaml_value "password" "")
  hostname=$(get_yaml_value "hostname" "omarchy")
  timezone=$(get_yaml_value "timezone" "UTC")
  keyboard=$(get_yaml_value "keyboard" "us")
  ssh_keys=$(get_ssh_keys)

  # Validate required fields
  if [[ -z "$username" ]]; then
    die "username is required in cloud-init config"
  fi
  if [[ -z "$password" ]]; then
    die "password is required in cloud-init config"
  fi

  log "Configuration:"
  log "  username: $username"
  log "  hostname: $hostname"
  log "  timezone: $timezone"
  log "  keyboard: $keyboard"
  log "  ssh_keys: $(echo "$ssh_keys" | jq -r 'length') key(s)"

  # Find installation disk
  disk=$(find_install_disk)

  # Hash the password
  local password_hash
  password_hash=$(hash_password "$password")

  # Generate configuration files
  generate_user_configuration "$disk" "$hostname" "$timezone" "$keyboard"
  generate_user_credentials "$username" "$password_hash"
  generate_placeholder_files "$username"

  # Prepare SSH keys for post-install
  setup_ssh_keys "$username" "$ssh_keys"

  # Unmount cloud-init drive
  umount "$CIDATA_MOUNT" || true

  log "Configuration complete, ready for archinstall"
}

# Allow sourcing for post-install functions
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi
