#!/usr/bin/env bash
# Unattended install script for Packer/Proxmox
# Reads configuration from cloud-init drive and generates archinstall JSON files
set -euo pipefail

CIDATA_MOUNT="/tmp/cidata"
USERDATA_FILE="$CIDATA_MOUNT/user-data"

log() {
  echo "[autoinstall] $*"
}

die() {
  echo "[autoinstall] ERROR: $*" >&2
  exit 1
}

# Find and mount the cloud-init drive (labeled 'cidata')
mount_cidata() {
  log "Looking for cloud-init drive..."

  local cidata_dev=""

  # Look for device with label 'cidata' or 'CIDATA'
  for label in cidata CIDATA; do
    if [[ -e "/dev/disk/by-label/$label" ]]; then
      cidata_dev=$(readlink -f "/dev/disk/by-label/$label")
      break
    fi
  done

  if [[ -z "$cidata_dev" ]]; then
    die "No cloud-init drive found (looking for label 'cidata')"
  fi

  log "Found cloud-init drive at $cidata_dev"

  mkdir -p "$CIDATA_MOUNT"
  mount -o ro "$cidata_dev" "$CIDATA_MOUNT" || die "Failed to mount cloud-init drive"

  if [[ ! -f "$USERDATA_FILE" ]]; then
    die "No user-data file found on cloud-init drive"
  fi

  log "Cloud-init drive mounted successfully"
}

# Parse YAML user-data file (simple parser for our specific format)
# Usage: get_yaml_value "key" "default"
get_yaml_value() {
  local key="$1"
  local default="${2:-}"
  local value=""

  # Look for key under autoinstall section
  value=$(sed -n '/^autoinstall:/,/^[^ ]/p' "$USERDATA_FILE" | \
          grep "^  $key:" | \
          sed "s/^  $key: *//" | \
          sed 's/^["'\'']\(.*\)["'\'']$/\1/' | \
          head -1)

  if [[ -z "$value" ]]; then
    echo "$default"
  else
    echo "$value"
  fi
}

# Get SSH authorized keys as a JSON array
get_ssh_keys() {
  local keys=()
  local in_keys_section=false

  while IFS= read -r line; do
    if [[ "$line" =~ ^[[:space:]]*ssh_authorized_keys: ]]; then
      in_keys_section=true
      continue
    fi

    if $in_keys_section; then
      # Check if we've left the keys section (line doesn't start with dash or space)
      if [[ "$line" =~ ^[[:space:]]*- ]]; then
        # Extract the key (remove leading "- " and quotes)
        local key=$(echo "$line" | sed 's/^[[:space:]]*-[[:space:]]*//' | sed 's/^["'\'']\(.*\)["'\'']$/\1/')
        keys+=("$key")
      elif [[ ! "$line" =~ ^[[:space:]] ]] && [[ -n "$line" ]]; then
        break
      fi
    fi
  done < "$USERDATA_FILE"

  # Output as JSON array
  if [[ ${#keys[@]} -eq 0 ]]; then
    echo "[]"
  else
    printf '%s\n' "${keys[@]}" | jq -R . | jq -s .
  fi
}

# Find the best disk for installation (skip ISO and small disks)
find_install_disk() {
  local disk_config
  disk_config=$(get_yaml_value "disk" "auto")

  if [[ "$disk_config" != "auto" ]]; then
    # User specified a specific disk
    if [[ -b "/dev/$disk_config" ]]; then
      echo "/dev/$disk_config"
      return
    elif [[ -b "$disk_config" ]]; then
      echo "$disk_config"
      return
    else
      die "Specified disk '$disk_config' not found"
    fi
  fi

  # Auto-select: find first suitable disk
  log "Auto-selecting installation disk..."

  local selected=""

  for disk in /dev/sd[a-z] /dev/vd[a-z] /dev/nvme[0-9]n[0-9]; do
    [[ -b "$disk" ]] || continue

    # Skip if this is the boot ISO (check if it's a CD-ROM or has ISO filesystem)
    local disk_name=$(basename "$disk")
    if [[ -d "/sys/block/$disk_name" ]]; then
      # Skip CD-ROMs
      local removable=$(cat "/sys/block/$disk_name/removable" 2>/dev/null || echo "0")
      if [[ "$removable" == "1" ]]; then
        log "Skipping $disk (removable media)"
        continue
      fi

      # Skip small disks (less than 10GB)
      local size_bytes=$(cat "/sys/block/$disk_name/size" 2>/dev/null || echo "0")
      local size_gb=$((size_bytes * 512 / 1024 / 1024 / 1024))
      if [[ $size_gb -lt 10 ]]; then
        log "Skipping $disk (too small: ${size_gb}GB)"
        continue
      fi
    fi

    selected="$disk"
    break
  done

  if [[ -z "$selected" ]]; then
    die "No suitable disk found for installation"
  fi

  log "Selected disk: $selected"
  echo "$selected"
}

# Hash password using openssl (same format archinstall expects)
hash_password() {
  local password="$1"
  openssl passwd -6 "$password"
}

# Generate user_configuration.json
generate_user_configuration() {
  local disk="$1"
  local hostname="$2"
  local timezone="$3"
  local keyboard="$4"

  log "Generating user_configuration.json..."

  cat > user_configuration.json << EOF
